{
  "name": "@moodcode/shared",
  "version": "0.0.1",
  "private": true,
  "sideEffects": false,
  "main": "./dist/cjs/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run compile",
    "compile": "npm run clean && tsc -p tsconfig.cjs.json && node scripts/ensure-esm-package.cjs && tsc -p tsconfig.esm.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}