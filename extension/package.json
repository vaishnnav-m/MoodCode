{
  "name": "moodcode",
  "displayName": "MoodCode",
  "description": "Switch your VS Code theme automatically based on time of day and your personal mood config.",
  "version": "0.0.1",
  "publisher": "moodcode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": ["Themes", "Other"],
  "keywords": ["theme", "mood", "time", "productivity"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "moodcode.override", "title": "Set Mood Override…", "category": "MoodCode" },
      { "command": "moodcode.refresh", "title": "Refresh Mood", "category": "MoodCode" },
      { "command": "moodcode.openDashboard", "title": "Open Dashboard", "category": "MoodCode" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "moodcode.override" },
        { "command": "moodcode.refresh" },
        { "command": "moodcode.openDashboard" }
      ]
    },
    "configuration": {
      "title": "MoodCode",
      "properties": {
        "moodcode.backendUrl": {
          "type": "string",
          "default": "https://moode-code-api.onrender.com",
          "description": "Base URL for the MoodCode backend REST API."
        },
        "moodcode.wsUrl": {
          "type": "string",
          "default": "wss://moode-code-api.onrender.com",
          "description": "WebSocket URL for real-time config updates from the dashboard."
        },
        "moodcode.pollIntervalMs": {
          "type": "number",
          "default": 60000,
          "minimum": 10000,
          "description": "How often to re-evaluate mood from the time signal (milliseconds)."
        },
        "moodcode.dashboardUrl": {
          "type": "string",
          "default": "http://localhost:5173",
          "description": "URL of the MoodCode config dashboard."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --target=node18 --format=cjs --conditions=require --log-level=info",
    "compile": "tsc -p ./",
    "watch": "npm run bundle -- --watch",
    "lint": "eslint src",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@moodcode/shared": "file:../shared",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}