# MoodCode — environment variable template
# Copy to backend/.env when the backend package is set up (never commit .env).

# MongoDB connection (local dev)
MONGODB_URI=mongodb://localhost:27017/moodcode

# Express + WebSocket server port
PORT=3001

# Reserved for future Spotify OAuth sessions (not used in MVP)
SESSION_SECRET=your_secret_here

# Dashboard (localhost:5173) — no .env needed; Vite proxy handles /api in dev.
